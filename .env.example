APP_NAME=kukufiti-api
DEBUG=true
LOG_LEVEL=info
SECRET_KEY=change_this_to_a_real_secret_in_production

POSTGRES_USER=fred
POSTGRES_PASSWORD=postgres_local
POSTGRES_DB=kukufiti_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# Use these values when running the API locally from the IDE while Postgres runs in Docker.
DATABASE_URL=postgresql://fred:postgres_local@localhost:5434/kukufiti_dev
BATCHES_DB_URL=postgresql://batches_app:batches_dev@localhost:5434/kukufiti_dev
FINANCE_DB_URL=postgresql://finance_app:finance_dev@localhost:5434/kukufiti_dev
HEALTH_DB_URL=postgresql://health_app:health_dev@localhost:5434/kukufiti_dev
AUTH_DB_URL=postgresql://auth_app:auth_dev@localhost:5434/kukufiti_dev
